# ZAWAbfallkalenderZuGoogleCalendarURL – Lokale Konfiguration
# Kopiere diese Datei nach .env und trage deine Werte ein.
# .env wird NICHT ins Repository committed (siehe .gitignore).
#
# Für die Vercel-Deployment-Variante werden die Parameter stattdessen
# als URL-Query-Parameter übergeben (?city=...&street=...&nr=...).

# --- Pflichtfelder: Adresse ---
CITY=Meine-Gemeinde
STREET=Meine Straße
HOUSE_NUMBER=1

# --- ICS-Feed ---
CAL_NAME=Abfall (ZAW)
# OUTPUT=abfall.ics
# UID_DOMAIN=zaw-abfall.local

# --- Optional: Verhalten anpassen ---
# MORNING_ALL_DAY=true
# MORNING_TIME=06:00
# EVENING_TIME=22:00
# EVENING_OFFSET_DAYS=1
# EVENT_DURATION_MIN=15
# ALARM_MIN_BEFORE=0
# DAYS_BACK=7
# DAYS_AHEAD=400
